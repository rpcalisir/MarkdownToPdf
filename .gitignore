# ------------------------------------------------------------------------------
# 1. BUILD OUTPUTS & DEPENDENCIES
# ------------------------------------------------------------------------------
[Bb]in/
[Oo]bj/
[Oo]ut/
artifacts/
*.nupkg
*.snupkg
node_modules/

# ------------------------------------------------------------------------------
# 2. IDE & TOOLING (Visual Studio, VS Code, Rider)
# ------------------------------------------------------------------------------
.vs/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.user
*.userosscache
*.sln.docstates
*.suo
*.v3
*.vssscc
*.vspscc

# ReSharper / DotCover
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user
*.dotCover

# ------------------------------------------------------------------------------
# 3. TEST RESULTS & PLAYWRIGHT E2E
# ------------------------------------------------------------------------------
[Tt]est[Rr]esult*/
*.trx
*.coverage
*.coveragexml
coverage*.json
coverage*.xml
coverage*.info

# Playwright Specific
test-results/
playwright-report/
playwright/.cache/
blob-report/

# ------------------------------------------------------------------------------
# 4. DATABASES & LOCAL SECRETS
# ------------------------------------------------------------------------------
# Ignore local SQLite databases
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Environment variables and local secrets
*.env
appsettings.Local.json

# ------------------------------------------------------------------------------
# 5. LOGS, CACHE & TRACES
# ------------------------------------------------------------------------------
[Ll]ogs/
*.log
*.tmp
*.cache
*.[Cc]ache/

# We commented this out because it conflicts with the PortfolioBuddy.Web.Tests.E2E folder name
# *.e2e

# ------------------------------------------------------------------------------
# 6. EXCEPTIONS & CUSTOM PROJECT RULES
# ------------------------------------------------------------------------------
