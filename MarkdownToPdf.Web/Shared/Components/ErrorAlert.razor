@namespace MarkdownToPdf.Web.Shared.Components

<div id="@alertId"
     hx-on:htmx:load="setTimeout(() => this.remove(), 1000)"
     class="bg-red-50 border-l-4 border-red-500 p-4 mb-4 rounded shadow-lg relative flex justify-between items-start transition-all duration-300" role="alert">
    <div class="flex">
        <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800">Action Required</h3>
            <div class="mt-2 text-sm text-red-700">
                <ul class="list-disc pl-5 space-y-1">
                    @foreach (var error in Errors)
                    {
                        <li>@error</li>
                    }
                </ul>
            </div>
        </div>
    </div>
    
    <button type="button"
            hx-on:click="document.getElementById('@alertId').remove()"
            class="ml-auto flex-shrink-0 inline-flex text-red-500 hover:text-red-700 focus:outline-none">
        <span class="sr-only">Close</span>
        <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path d="M6.28 5.22a.75.75 0 00-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 101.06 1.06L10 11.06l3.72 3.72a.75.75 0 101.06-1.06L11.06 10l3.72-3.72a.75.75 0 00-1.06-1.06L10 8.94 6.28 5.22z" />
        </svg>
    </button>
</div>

@code {
    [Parameter]
    public List<string> Errors { get; set; } = new();

    private readonly string alertId = $"error-toast-{Guid.NewGuid():N}";
}