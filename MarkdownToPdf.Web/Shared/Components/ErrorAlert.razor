@using MarkdownToPdf.Web.Shared.Components

@if (Errors != null && Errors.Any())
{
    // HTMX gracefully swaps this in, and we use basic CSS animation to make it slide in
    <div class="bg-white border-l-4 border-red-500 shadow-2xl rounded-lg p-5 animate-fade-in transition-all" role="alert">
        <div class="flex items-start">
            <div class="flex-shrink-0">
                <svg class="h-6 w-6 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                </svg>
            </div>
            <div class="ml-3 w-0 flex-1 pt-0.5">
                <h3 class="text-sm font-bold text-gray-900">Validation Error</h3>
                <div class="mt-1 text-sm text-gray-600">
                    <ul class="list-disc pl-5 space-y-1">
                        @foreach (var error in Errors)
                        {
                            <li>@error</li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>
    
    // Auto-dismiss script strictly for UI cleanup
    <script>
        setTimeout(() => {
            const toast = document.getElementById('toast-container');
            if (toast) toast.innerHTML = '';
        }, 5000);
    </script>
}

@code {
    [Parameter]
    public List<string> Errors { get; set; } = new();
}