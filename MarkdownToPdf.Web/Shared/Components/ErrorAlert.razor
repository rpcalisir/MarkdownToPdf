@namespace MarkdownToPdf.Web.Shared.Components

@if (Errors != null && Errors.Any())
{
    <div id="htmx-error-toast" class="bg-red-50 border-l-4 border-red-500 p-4 mb-4 shadow-lg transition-opacity duration-500 opacity-100 rounded-r-md" role="alert">
        <div class="flex justify-between items-start">
            <div class="flex-1">
                <h3 class="text-sm font-bold text-red-800">Action Required</h3>
                <div class="mt-2 text-sm text-red-700">
                    <ul class="list-disc pl-5 space-y-1 font-medium">
                        @foreach (var error in Errors)
                        {
                            <li>@error</li>
                        }
                    </ul>
                </div>
            </div>
            <button type="button" class="ml-auto -mx-1.5 -my-1.5 bg-red-50 text-red-500 rounded-lg p-1.5 hover:bg-red-100 focus:ring-2 focus:ring-red-400 transition-colors" onclick="document.getElementById('htmx-error-toast').remove();">
                <span class="sr-only">Dismiss</span>
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path>
                </svg>
            </button>
        </div>
    </div>

    <script>
        // Scoped script to handle the auto-dismissal lifecycle
        setTimeout(() => {
            const toast = document.getElementById('htmx-error-toast');
            if (toast) {
                // Trigger Tailwind's transition-opacity
                toast.classList.remove('opacity-100');
                toast.classList.add('opacity-0');

                // Wait for the 500ms CSS fade transition to finish before removing from DOM
                setTimeout(() => toast.remove(), 500);
            }
        }, 3000); // Enforce a strict 3-second visibility window
    </script>
}

@code {
    [Parameter]
    public List<string> Errors { get; set; } = new();
}