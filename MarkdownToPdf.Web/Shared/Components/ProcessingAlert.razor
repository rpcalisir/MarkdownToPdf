@using MarkdownToPdf.Web.Shared.Constants

<div id="processing-toast"
     hx-get="@($"{Api.Routes.PdfGeneration.Prefix}/status/{JobId}")"
     hx-trigger="every 2s"
     hx-swap="outerHTML"
     class="fixed top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 z-[100] w-96 max-w-sm bg-white border-t-4 border-blue-500 shadow-2xl rounded-xl p-6"
     role="alert">
    <div class="flex items-start">
        <div class="flex-shrink-0 animate-spin mt-1">
            <svg class="h-6 w-6 text-blue-500" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
        </div>
        <div class="ml-4 w-0 flex-1">
            <h3 class="text-md font-bold text-gray-900">Generating PDF</h3>
            <div class="mt-1 text-sm text-gray-500">
                <p>Your document is being processed securely. Please wait...</p>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public Guid JobId { get; set; }
}