@* Features/PdfGeneration/Preview/Templates/MarkdownPreviewTemplate.razor *@
@* Encapsulates the raw HTML string generated by Markdig to safely inject it into the DOM *@

<div class="prose max-w-none text-gray-800">
    @((MarkupString)HtmlContent)
</div>

@code {
    [Parameter, EditorRequired]
    public required string HtmlContent { get; set; }
}